# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real tokens or local paths.

# ─── Figma ────────────────────────────────────────────────────────────────────

# Your Figma personal access token.
# Generate one at: figma.com → Settings → Security → Personal access tokens
FIGMA_PAT=your_figma_personal_access_token_here

# Override the MCP server URL if your Figma desktop app runs on a different port.
# Default is http://127.0.0.1:3845/mcp — leave blank to use the default.
FIGMA_MCP_URL=

# Note: Figma file keys and node IDs live in figma-registry.yml, not here.
# Add a new entry there for each component — no env vars needed for file keys.

# ─── Codebase ─────────────────────────────────────────────────────────────────

# Absolute path to the codebase where components will be built or updated.
# Example: /Users/you/projects/my-design-system
CODEBASE_PATH=/path/to/your/target/codebase